{
  "info": {
    "_postman_id": "hrm-api",
    "name": "HRM API",
    "description": "HRM System API collection for authentication, employee management, and attendance tracking. Attendance check-in/check-out now uses GPS validation and can optionally require company Wi-Fi/IP via COMPANY_WIFI_IPS on the backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"employee1@hrm.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
          "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@hrm.com\",\n  \"password\": \"password\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      },
      "response": [
        {
          "name": "200 - Success",
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": true,\n  \"message\": \"Đăng nhập thành công\",\n  \"data\": {\n    \"user\": {\n      \"id\": 1,\n      \"email\": \"admin@hrm.com\",\n      \"role\": 1,\n      \"role_name\": \"Admin\",\n      \"status\": 1,\n      \"status_name\": \"Active\"\n    },\n    \"token\": \"1|abc123xyz\"\n  }\n}"
        }
      ]
    },
    {
      "name": "Get Current User",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": ["{{base_url}}"],
          "path": ["auth", "me"]
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": ["{{base_url}}"],
          "path": ["auth", "logout"]
        }
      }
    },
    {
      "name": "Change Password",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"password\",\n  \"new_password\": \"newpassword123\",\n  \"new_password_confirmation\": \"newpassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/change-password",
          "host": ["{{base_url}}"],
          "path": ["auth", "change-password"]
        }
      }
    },
    {
      "name": "Forgot Password (Request OTP)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@hrm.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/forgot-password",
          "host": ["{{base_url}}"],
          "path": ["auth", "forgot-password"]
        }
      },
      "response": [
        {
          "name": "200 - Success (Generic Message)",
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": true,\n  \"message\": \"Nếu email tồn tại, hệ thống đã gửi OTP đặt lại mật khẩu.\"\n}"
        },
        {
          "name": "429 - Rate Limited",
          "status": "Too Many Requests",
          "code": 429,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": false,\n  \"message\": \"Too many requests. Please try again later.\",\n  \"retry_after_seconds\": 45\n}"
        }
      ]
    },
    {
      "name": "Reset Password (Verify OTP)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@hrm.com\",\n  \"token\": \"123456\",\n  \"password\": \"newpassword123\",\n  \"password_confirmation\": \"newpassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/reset-password",
          "host": ["{{base_url}}"],
          "path": ["auth", "reset-password"]
        }
      },
      "response": [
        {
          "name": "200 - Success",
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": true,\n  \"message\": \"Đặt lại mật khẩu thành công. Vui lòng đăng nhập lại.\"\n}"
        },
        {
          "name": "400 - Invalid or Expired OTP",
          "status": "Bad Request",
          "code": 400,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": false,\n  \"message\": \"OTP không hợp lệ hoặc đã hết hạn.\"\n}"
        },
        {
          "name": "429 - Too Many Failed OTP Attempts",
          "status": "Too Many Requests",
          "code": 429,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"success\": false,\n  \"message\": \"Bạn đã nhập sai OTP quá nhiều lần. Vui lòng thử lại sau.\",\n  \"retry_after_seconds\": 300\n}"
        }
      ]
    }
      ]
    },
    {
