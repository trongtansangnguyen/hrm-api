    {
      "name": "Attendance",
      "description": "Attendance flow for employees. Check-in/check-out requires Bearer token, valid GPS coordinates, and may also require the request IP to match company Wi-Fi/IP ranges configured on the server.",
      "item": [
        {
          "name": "Get Today Attendance",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/attendance/today",
              "host": ["{{base_url}}"],
              "path": ["attendance", "today"]
            }
          }
        },
        {
          "name": "Check In",
          "request": {
            "description": "Employee check-in. Requires latitude/longitude inside company radius. If backend COMPANY_WIFI_IPS is configured, the request must also come from company Wi-Fi/IP. Send X-Device-Id for device tracking.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-Device-Id",
                "value": "dev-local-001"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": -6.2000000,\n  \"longitude\": 106.8166667\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/check-in",
              "host": ["{{base_url}}"],
              "path": ["attendance", "check-in"]
            }
          }
        },
        {
          "name": "Check Out",
          "request": {
            "description": "Employee check-out. Requires latitude/longitude inside company radius. If backend COMPANY_WIFI_IPS is configured, the request must also come from company Wi-Fi/IP.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": -6.2000000,\n  \"longitude\": 106.8166667\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/check-out",
              "host": ["{{base_url}}"],
              "path": ["attendance", "check-out"]
            }
          }
        }
      ]
    }
  ]
