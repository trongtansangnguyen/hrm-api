              "body": "{\n  \"success\": true,\n  \"message\": \"Tạo nhân viên thành công\",\n  \"data\": {\n    \"id\": 1,\n    \"employee_code\": \"EMP001\",\n    \"first_name\": \"Nguyen\",\n    \"last_name\": \"Van A\",\n    \"full_name\": \"Nguyen Van A\",\n    \"gender\": \"male\",\n    \"date_of_birth\": \"1990-01-15\",\n    \"phone\": \"0123456789\",\n    \"email\": \"nguyenvana@example.com\",\n    \"address\": \"123 Street, District, City\",\n    \"identity_number\": \"001234567890\",\n    \"join_date\": \"2024-01-01 00:00:00\",\n    \"status\": \"working\",\n    \"department_id\": 1,\n    \"department\": {\n      \"id\": 1,\n      \"name\": \"IT Department\"\n    },\n    \"position_id\": 1,\n    \"position\": {\n      \"id\": 1,\n      \"name\": \"Developer\"\n    },\n    \"created_at\": \"2024-01-01 00:00:00\",\n    \"updated_at\": \"2024-01-01 00:00:00\"\n  }\n}"
