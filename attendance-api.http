@baseUrl = http://localhost:8000
@token =

### Login
POST {{baseUrl}}/auth/login
Accept: application/json
Content-Type: application/json

{
  "email": "admin@hrm.com",
  "password": "password"
}

### Note
# Attendance requests require GPS coordinates in company radius.
# If backend env COMPANY_WIFI_IPS is configured, requests must also come from company Wi-Fi/IP.

### Debug - My IP
GET {{baseUrl}}/debug/my-ip
Accept: application/json

### Attendance - Today
GET {{baseUrl}}/attendance/today
Accept: application/json
Authorization: Bearer {{token}}

### Attendance - Check In
POST {{baseUrl}}/attendance/check-in
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}
X-Device-Id: dev-local-001

{
  "latitude": -6.2000000,
  "longitude": 106.8166667
}

### Attendance - Check Out
POST {{baseUrl}}/attendance/check-out
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "latitude": -6.2000000,
  "longitude": 106.8166667
}
